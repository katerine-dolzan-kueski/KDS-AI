{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "build-tests",
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src/**/*", "src/test/**/*", "**/*.stories.*", "**/*.test.*"]
}
