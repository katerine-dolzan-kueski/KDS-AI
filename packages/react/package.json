{
  "name": "@kueski-dev/kds-react",
  "version": "2.30.0",
  "description": "kueski design system is a library of React components",
  "keywords": [
    "react",
    "react-component",
    "kds"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kueski-dev/kueski-design-system.git",
    "directory": "packages/react"
  },
  "homepage": "https://kueski-design-system.com",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./atoms": {
      "types": "./dist/components/atoms/index.d.ts",
      "import": "./dist/components/atoms/index.es.js",
      "require": "./dist/components/atoms/index.cjs"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/*": "./dist/styles/*.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/clean.js dist \"*.tsbuildinfo\"",
    "build": "kds-utils build",
    "check:types": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:all": "pnpm test:run",
    "analyze": "ANALYZE=true pnpm run build"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react-day-picker": "^9.11.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@kueski-dev/kds-utils": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^12.1.5",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^16.14.0",
    "@types/react-dom": "^16.9.0",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-router": "^6.28.0",
    "rollup-plugin-visualizer": "^6.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@types/react": ">=16.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": ">=16.14.0",
    "react-dom": ">=16.14.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@kueski-dev"
  }
}
