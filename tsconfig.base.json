{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": false,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noErrorTruncation": false,
    "allowJs": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noImplicitThis": true,
    "noPropertyAccessFromIndexSignature": false,
    "noFallthroughCasesInSwitch": true,
    "allowUnreachableCode": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@kueski-dev/kds-legacy": ["./packages/react-legacy/src"],
      "@kueski-dev/kds-legacy/*": ["./packages/react-legacy/src/*"],
      "@kueski-dev/kds-react": ["./packages/react/src"],
      "@kueski-dev/kds-react/*": ["./packages/react/src/*"],
      "@kueski-dev/kds-utils/*": ["./packages/utils/src/*"],
      "@kueski-dev/kds-utils/": ["./packages/utils/src"]
    }
  },
  "exclude": [
    "**/.*/",
    "**/build",
    "**/dist",
    "**/build-tests",
    "**/node_modules",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "**/test/**/*",
    "**/.nx/**/*",
    "**/dist/**/*",
    "**/coverage/**/*",
    "**/.github/**/*",
    "**/.husky/**/*",
    "**/.storybook/**/*",
    "**/.tf/**/*",
    "**/cli/**/*",
    "**/scripts/**/*"
  ]
}
