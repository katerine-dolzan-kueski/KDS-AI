### 4. Interactive Stories

```typescript
export const Interactive: Story = {
  args: {
    children: 'Click me',
    $variant: 'primary',
  },
  play: async ({ canvasElement }) => {
    const canvas = within(canvasElement);
    const button = canvas.getByRole('button');

    await userEvent.click(button);
    // Test interactions
  },
};
```

## Story Documentation

### 1. JSDoc in Stories

````typescript
/**
 * Primary button variant - main brand color
 *
 * @example
 * ```tsx
 * <Button $variant="primary" $size="md">
 *   Click me
 * </Button>
 * ```
 */
export const Primary: Story = {
  args: {
    children: 'Primary Button',
    $variant: 'primary',
  },
};
````

### 2. Parameters and Controls

```typescript
const meta: Meta<typeof Button> = {
  title: 'Atoms/Button',
  component: Button,
  parameters: {
    docs: {
      description: {
        component: 'A versatile button component with multiple variants and sizes.',
      },
    },
  },
  argTypes: {
    $variant: {
      description: 'Visual variant of the button',
      control: 'select',
      options: ['primary', 'secondary', 'destructive'],
      table: {
        type: { summary: 'ButtonVariant' },
        defaultValue: { summary: 'primary' },
      },
    },
    $size: {
      description: 'Size of the button',
      control: 'select',
      options: ['sm', 'md', 'lg'],
      table: {
        type: { summary: 'ButtonSize' },
        defaultValue: { summary: 'md' },
      },
    },
    $loading: {
      description: 'Show loading state',
      control: 'boolean',
      table: {
        type: { summary: 'boolean' },
        defaultValue: { summary: 'false' },
      },
    },
  },
};
```

### 3. Decorators

```typescript
export const WithIcon: Story = {
  args: {
    children: 'Button with Icon',
    $variant: 'primary',
  },
  decorators: [
    (Story) => (
      <div className="flex items-center gap-2">
        <Icon name="plus" />
        <Story />
      </div>
    ),
  ],
};
```

## Testing in Stories

### 1. Accessibility Testing

```typescript
export const AccessibilityTest: Story = {
  args: {
    children: 'Accessible Button',
    $ariaLabel: 'Custom accessible label',
  },
  play: async ({ canvasElement }) => {
    const canvas = within(canvasElement);
    const button = canvas.getByRole('button');

    // Test focus
    button.focus();
    expect(button).toHaveFocus();

    // Test keyboard navigation
    await userEvent.keyboard('{Enter}');
    // Test interactions
  },
};
```

### 2. Visual Regression Testing

```typescript
export const VisualRegression: Story = {
  args: {
    children: 'Visual Test',
    $variant: 'primary',
  },
  parameters: {
    chromatic: {
      disableSnapshot: false,
      viewports: [320, 768, 1024],
    },
  },
};
```

## Story Organization

### 1. Title Structure

```typescript
// Atoms
title: 'Atoms/Button';
title: 'Atoms/Input';
title: 'Atoms/Icon';

// Molecules
title: 'Molecules/SearchBox';
title: 'Molecules/FormField';

// Organisms
title: 'Organisms/Header';
title: 'Organisms/Sidebar';

// Patterns
title: 'Patterns/Layout';
title: 'Patterns/Form';
```

### 2. Tags and Categorization

```typescript
const meta: Meta<typeof Button> = {
  title: 'Atoms/Button',
  component: Button,
  tags: ['autodocs', 'accessibility', 'interactive'],
  parameters: {
    docs: {
      category: 'Interactive Elements',
    },
  },
};
```

## Best Practices

### 1. Naming Conventions

```typescript
// ✅ Good - descriptive names
export const PrimaryVariant: Story = { ... };
export const LoadingState: Story = { ... };
export const WithIcon: Story = { ... };

// ❌ Bad - generic names
export const Default: Story = { ... };
export const Test: Story = { ... };
export const Example: Story = { ... };
```

### 2. Args Consistency

```typescript
// ✅ Good - consistent args
export const Primary: Story = {
  args: {
    children: 'Primary Button',
    $variant: 'primary',
    $size: 'md',
  },
};

export const Secondary: Story = {
  args: {
    children: 'Secondary Button',
    $variant: 'secondary',
    $size: 'md', // Same size for consistency
  },
};
```

### 3. Responsive Testing

```typescript
export const Responsive: Story = {
  args: {
    children: 'Responsive Button',
    $variant: 'primary',
  },
  parameters: {
    viewport: {
      viewports: {
        mobile: {
          name: 'Mobile',
          styles: { width: '375px', height: '667px' },
        },
        tablet: {
          name: 'Tablet',
          styles: { width: '768px', height: '1024px' },
        },
        desktop: {
          name: 'Desktop',
          styles: { width: '1024px', height: '768px' },
        },
      },
    },
  },
};
```

## Recommended Addons

### 1. Controls

```typescript
// Controls configuration
argTypes: {
  $variant: {
    control: 'select',
    options: ['primary', 'secondary', 'destructive'],
  },
  $size: {
    control: 'select',
    options: ['sm', 'md', 'lg'],
  },
  $loading: {
    control: 'boolean',
  },
  children: {
    control: 'text',
  },
};
```

### 2. Actions

```typescript
export const WithActions: Story = {
  args: {
    children: 'Button with Actions',
    onClick: action('clicked'),
    onFocus: action('focused'),
    onBlur: action('blurred'),
  },
};
```

### 3. Viewport

```typescript
parameters: {
  viewport: {
    defaultViewport: 'mobile',
    viewports: {
      mobile: {
        name: 'Mobile',
        styles: { width: '375px', height: '667px' },
      },
    },
  },
};
```

## Story Checklist

- [ ] Basic story with default props
- [ ] All variants documented
- [ ] All states (loading, disabled, error)
- [ ] All sizes
- [ ] Interactive story with user events
- [ ] Accessibility story
- [ ] Responsive story
- [ ] Consistent args between stories
- [ ] JSDoc documentation
- [ ] Controls configured
- [ ] Actions for events
- [ ] Appropriate tags
- [ ] Correct categorization
